# Project .gitignore for Lexicon workspace

# Node / frontend
node_modules/
**/node_modules/
dist/
.vite/
build/
npm-debug.log
yarn-debug.log
yarn-error.log
pnpm-debug.log

# Vite / TypeScript
*.tsbuildinfo

# Environment
.env
.env.*.local

# Rust / Tauri
/lexicon/src-tauri/target/
target/
**/target/

# Plugin wasm artifacts (built output)
/lexicon/src-tauri/plugins/dist/
*.wasm

# Plugin build dirs
/lexicon/src-tauri/plugins/*/target/

# Python virtualenvs
.venv/
venv/
env/

# Python cache
__pycache__/
*.py[cod]

# Databases / runtime artifacts
*.db
*.sqlite
lexicon.db

# IDEs and editors
.vscode/
.idea/
*.iml

# OS files
.DS_Store

# Logs
*.log

# Coverage / reports
coverage/

# Misc
/.cache/
/.history/
