{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nossateca",
  "version": "0.1.0",
  "identifier": "lexicon",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Nossateca",
        "width": 800,
        "height": 600,
        "decorations": true,
        "resizable": true,
        "transparent": true,
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "plugins/dist/*.wasm"
    ]
  }
}
